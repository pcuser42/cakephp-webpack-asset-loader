{
    "name": "pcuser42/cakephp-webpack-asset-loader",
    "description": "CakePHP plugin for loading Webpack entrypoint assets from entrypoints.json.",
    "type": "cakephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Melchior @ Interweber",
            "homepage": "https://github.com/interweberde",
            "role": "Author"
        },
        {
            "name": "Alex Burgess",
            "homepage": "https://github.com/pcuser42",
            "role": "Author"
        }
    ],
    "support": {
        "issues": "https://github.com/pcuser42/cakephp-webpack-asset-loader/issues",
        "source": "https://github.com/pcuser42/cakephp-webpack-asset-loader"
    },
    "require": {
        "php": ">=8.3",
        "cakephp/cakephp": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2.7",
        "rector/rector": "^2.0.3"
    },
    "autoload": {
        "psr-4": {
            "Pcuser42\\WebpackAssetLoader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pcuser42\\WebpackAssetLoader\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    }
}
